# 複製成 .env 並填入你的 Anthropic API 金鑰
ANTHROPIC_API_KEY=

# （選填）後端 provider：claude（預設）或 openai
# TI_PROVIDER=claude

# （選填）覆寫各角色使用的 Claude 模型
# TI_MODEL_LEAD=claude-opus-4-8
# TI_MODEL_FAST=claude-sonnet-4-6

# （選填）用 OpenAI 或本地相容模型（需 TI_PROVIDER=openai）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=http://localhost:11434/v1   # 例：Ollama / LM Studio 等本地模型
# TI_OPENAI_MODEL_LEAD=gpt-4o
# TI_OPENAI_MODEL_FAST=gpt-4o-mini

# （選填）伺服器設定
# TI_HOST=0.0.0.0
# TI_PORT=8000
# TI_MAX_ROUNDS=3

# （選填）跨場次教訓庫（工作室長期記憶）：每場討論的檢討會蒸餾出可重用「教訓」存入
# lessons.json，下次新討論開場注入 PM 拆解——避免重蹈覆轍、善用既有結論，越做越會。
# 預設關閉（opt-in，與 NOTES/HUDDLE/CRITIC 一致）；lessons.json 已列入 .gitignore。
# 註：自我演化迴圈 deploy/ti-autopilot.service 已內建 TI_LESSONS=1，讓自我改善越跑越聚焦。
# TI_LESSONS=0          # 1 = 開啟跨場次教訓庫
# TI_LESSONS_MAX=12     # 注入 PM 拆解時取最新幾筆教訓
# TI_LESSONS_FILE=      # 自訂教訓庫路徑（預設專案根 lessons.json）

# （選填）立項/需求澄清：開場由 PM 評估需求是否模糊——模糊則列出至多 3 條關鍵問題，
# 等你用插話框回覆；逾時以明示假設續行（不卡死）。最終產出簡短 PRD 沉澱 docs/PRD.md，
# 抽出的「願景:」自動回填專案 meta（僅當原本為空）。預設開啟；improver/autopilot 自動跳過。
# TI_CLARIFY=1            # 1 = 開啟立項澄清（預設）；0 = 關閉（直接拆解）
# TI_CLARIFY_TIMEOUT=180  # 等待使用者回覆秒數

# （選填）知識沉澱：研究員調研結論與架構師設計決策持久化到 workspace 的
# docs/RESEARCH.md / docs/DECISIONS.md（PRD 見 docs/PRD.md），下場開場注入尾段。
# 專案模式 workspace 固定 → 知識跨場次累積、調研不重查。預設開啟（檔案不存在時零行為差）。
# TI_KNOWLEDGE=1             # 1 = 開啟知識沉澱（預設）；0 = 關閉
# TI_KNOWLEDGE_MAX_CHARS=4000  # 注入 prompt 的尾段字元上限

# 任務並行：一個需求內把彼此獨立的任務分「波次」並行，每條支線各自 git worktree
# 分支 + 獨立專家團隊，完工依序合併回主分支。預設開啟（功能已成熟）；要還原純循序設 0。
# PM 可逐行宣告 `依賴: #後 -> #前`；無相依的任務會被排進同一波次並行。
# TI_PARALLEL_TASKS=1          # 1 = 多支線並行（預設）；0 = 純循序
# TI_PARALLEL_LANES=3          # 單一波次內同時並行的支線數上限
# TI_LLM_MAX_CONCURRENCY=9     # 全域同時 LLM 發言數上限（節流；下限自動夾到 4 防自我死鎖）

# （選填）自我改進機制（移植自 ti-studio 自我進步交付，補主迴圈缺口）。屬「進階流程」開關，
# env 為來源，亦可在設定面板「進階」組調整（與 TI_LESSONS／NOTES／HUDDLE／CRITIC 一致）。穩健式預設：
# C 資源上限預設開（純加固、無行為風險）；A 反思／B 客觀閘門／D 自我精修預設關（opt-in）。
#
# A 反思記憶：失敗輪把 QA／高工意見蒸餾成反思存 per-session JSONL，後續輪／huddle 重試帶回 context
#（既有「上一輪原文回饋」照舊，本機制只補更早輪次的累積）。
# TI_REFLEXION=0          # 1 = 開啟任務級反思記憶
# TI_REFLEXION_MAX=5      # 注入時取最近幾筆反思
# B 客觀驗收閘門：交付前自測（smoke-run）實際執行失敗 → 該輪強制退回，不讓 QA／高工的文字裁決
# 推翻真實 exit code（守住反 reward-hacking）。
# TI_OBJECTIVE_GATE=0     # 0=關／1=開（自測實敗才否決）／strict=連「未宣告執行指令」也視為未通過
# D 單輪內自我精修：自測未過時，讓同一工程師就地依執行紀錄再修一次（交付驗證前）。
# TI_SELF_REFINE_ITERS=0  # 單輪內就地精修次數（0=關）
# C 子進程資源上限：runner 執行指令時套 RLIMIT，補 bwrap 沒有的記憶體／CPU／檔案大小防線。每項 0=略過。
# TI_RLIMITS=1            # 1 = 啟用資源上限（預設開）
# TI_RLIMIT_MEM_MB=4096   # 位址空間(RLIMIT_AS)上限 MB（V8／BLAS 會預留數 GB，故給寬鬆下限）
# TI_RLIMIT_CPU_S=300     # CPU 時間上限秒（遠高於 Demo wall timeout，只攔失控孤兒）
# TI_RLIMIT_FSIZE_MB=512  # 單檔可寫大小上限 MB（擋塞爆磁碟而不卡 pip wheel）

# （選填）登入門禁：設定密碼後，使用者需在登入頁輸入正確密碼才能進入工作室。
# 留空（預設）則完全停用認證。
# TI_ACCESS_PASSWORD=
# TI_AUTH_SECRET=          # 簽 cookie 的密鑰；留空則每次啟動隨機產生（重啟即登出所有人）
# TI_AUTH_TTL=604800       # 登入有效秒數（預設 7 天）

# （選填）反向代理 / 來源 IP 信任。預設關閉時完全忽略 X-Forwarded-For，只認 socket peer。
# 開啟後，僅當請求來自 TI_TRUSTED_PROXIES 內的受信代理，才採信其附加的 XFF 解析真實來源 IP
# （由右往左跳過受信代理、取最右非受信位址，不採信最左偽造值）。
# ⚠️ 安全警告：啟用 TI_TRUST_PROXY 時，務必確保 app port 僅受信代理可連得到；否則攻擊者
#    直連並偽造 XFF 即可冒充來源 IP（例如被誤判為本機）。app 與代理同機時尤其要鎖好防火牆。
# TI_TRUST_PROXY=0                       # 設 1（或 true/yes/on）才啟用
# TI_TRUSTED_PROXIES=127.0.0.0/8,::1     # 受信代理 IP/CIDR 逗號分隔，預設僅 loopback

# （選填）把工作室成果發佈到 GitHub（需同時設定 token 與 repo 才會啟用）
# GITHUB_TOKEN=ghp_xxx
# TI_PUBLISH_REPO=owner/repo
# TI_PUBLISH_BASE=main
# TI_PUBLISH_AUTO=0      # 設 1 則專案完成後自動發佈
# TI_PUBLISH_MERGE=0     # 設 1 則 push／開 PR 後自動合併進 base 分支（自我改進閉環）
#                        # ⚠️ 啟用＝AI 產出的 PR 無人複審即自動合併，搭配 /api/redeploy 會自動上線。
#                        # 啟用前請先設好分支保護 / CI gating。預設關閉。
# TI_PUBLISH_CI_TIMEOUT=600   # 自動合併前等待 CI 的最長秒數（逾時即放棄並回報，不無限等）
# TI_PUBLISH_CI_INTERVAL=10   # 等待 CI 的輪詢間隔（秒）
# TI_PUBLISH_MERGE_RETRIES=3  # 對 stale／Base branch was modified（409）的重試次數

# （選填）Autopilot 推送/合併安全旗標：兩者預設皆關閉（安全側）。
#         啟用前請先設好分支保護 / CI gating。風險與前提詳見 README「Autopilot 安全旗標補充」。
# TI_AUTOPILOT_FORCE_PUSH=0   # 預設非強制推送，遠端已存在同名分支即中止；設 1 才用
#                             # --force-with-lease --force-if-includes 覆寫殘留分支（絕不裸 -f）
# TI_AUTOPILOT_MERGE_ADMIN=0  # 預設不帶 gh pr merge --admin，讓分支保護生效；
#                             # 目標 branch 有保護規則且需自動合併時設 1
# TI_AUTOPILOT_PROTECTION_CHECK=1  # 第二道防線：squash-merge 前主動查合併目標分支的保護狀態；
#                             # 「無法確認」（403 無權/網路/逾時）一律 fail-safe 中止，絕不誤判放行。
#                             # 缺權限而持續卡住可設 0 整段跳過。原理、所需權限與保守行為詳見
#                             # README「Autopilot 安全旗標補充」。
# TI_AUTOPILOT_EVAL_MEMORY=20  # 自我評估（backlog 空時找改善點）回饋給專家的近期成敗筆數
#                             # （done/failed 各取最新 N 筆，附失敗原因）：避免重提已完成、
#                             # 避開已知失敗做法，讓迴圈越跑越聚焦。設 0 = 停用（無狀態評估）。

# （選填）專案與持續改良迴圈：專案=長期產品（固定 workspace + 專屬改良 backlog，跨場次累積）；
#         「持續改良」讓團隊自動消化 backlog、找問題、一直改良（UI 勾選「♻️ 持續改良」啟動）。
# TI_PROJECTS_ROOT=projects      # 專案 meta 與 backlog 的存放根目錄
# TI_IMPROVE_MAX_CYCLES=5        # 單次連線最多跑幾輪（每輪＝一場完整討論）；0=不限（直到收斂）
# TI_IMPROVE_MAX_FAILS=2         # 連續失敗幾輪即停（避免壞任務空轉燒額度）
# TI_IMPROVE_COOLDOWN=0          # 每輪之間喘息秒數

# （選填）歷史 / 工作區自動回收（GC）：每次 session 結束順手刪掉「非 running」且超量/過舊的
#         舊 session（含 history 的 meta+events 與其 workspace 產出），避免自托管長跑下
#         history/ 與 workspaces/ 只增不減塞爆磁碟。running 中的 session 一律保留。
# TI_HISTORY_MAX_COUNT=200  # 最多保留幾個非 running session（預設啟用）；設 0 還原成不自動回收
# TI_HISTORY_MAX_AGE=0      # 最後活動超過幾秒即回收（0=停用，opt-in 的時間保留策略）

# （選填）同時進行的討論場次上限：每場會起多個專家子程序 / LLM 連線，無上限時大量並發
#         連線可耗盡資源與 API 額度。超過時新的 /ws 連線被拒（送 error 後 close 1013）。
# TI_MAX_CONCURRENT_SESSIONS=8   # 0 = 不限（向後相容）；預設給寬鬆上限封住失控並發
