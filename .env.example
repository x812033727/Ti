# 複製成 .env 並填入你的 Anthropic API 金鑰
ANTHROPIC_API_KEY=

# （選填）後端 provider：claude（預設）或 openai
# TI_PROVIDER=claude

# （選填）覆寫各角色使用的 Claude 模型
# TI_MODEL_LEAD=claude-opus-4-8
# TI_MODEL_FAST=claude-sonnet-4-6

# （選填）用 OpenAI 或本地相容模型（需 TI_PROVIDER=openai）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=http://localhost:11434/v1   # 例：Ollama / LM Studio 等本地模型
# TI_OPENAI_MODEL_LEAD=gpt-4o
# TI_OPENAI_MODEL_FAST=gpt-4o-mini

# （選填）伺服器設定
# TI_HOST=0.0.0.0
# TI_PORT=8000
# TI_MAX_ROUNDS=3

# （選填）登入門禁：設定密碼後，使用者需在登入頁輸入正確密碼才能進入工作室。
# 留空（預設）則完全停用認證。
# TI_ACCESS_PASSWORD=
# TI_AUTH_SECRET=          # 簽 cookie 的密鑰；留空則每次啟動隨機產生（重啟即登出所有人）
# TI_AUTH_TTL=604800       # 登入有效秒數（預設 7 天）

# （選填）反向代理 / 來源 IP 信任。預設關閉時完全忽略 X-Forwarded-For，只認 socket peer。
# 開啟後，僅當請求來自 TI_TRUSTED_PROXIES 內的受信代理，才採信其附加的 XFF 解析真實來源 IP
# （由右往左跳過受信代理、取最右非受信位址，不採信最左偽造值）。
# ⚠️ 安全警告：啟用 TI_TRUST_PROXY 時，務必確保 app port 僅受信代理可連得到；否則攻擊者
#    直連並偽造 XFF 即可冒充來源 IP（例如被誤判為本機）。app 與代理同機時尤其要鎖好防火牆。
# TI_TRUST_PROXY=0                       # 設 1（或 true/yes/on）才啟用
# TI_TRUSTED_PROXIES=127.0.0.0/8,::1     # 受信代理 IP/CIDR 逗號分隔，預設僅 loopback

# （選填）把工作室成果發佈到 GitHub（需同時設定 token 與 repo 才會啟用）
# GITHUB_TOKEN=ghp_xxx
# TI_PUBLISH_REPO=owner/repo
# TI_PUBLISH_BASE=main
# TI_PUBLISH_AUTO=0      # 設 1 則專案完成後自動發佈
# TI_PUBLISH_MERGE=0     # 設 1 則 push／開 PR 後自動合併進 base 分支（自我改進閉環）
#                        # ⚠️ 啟用＝AI 產出的 PR 無人複審即自動合併，搭配 /api/redeploy 會自動上線。
#                        # 啟用前請先設好分支保護 / CI gating。預設關閉。

# （選填）Autopilot 推送/合併安全旗標，預設皆取安全側。
# TI_AUTOPILOT_FORCE_PUSH=0   # 預設非強制推送，遠端已存在同名分支即中止；設 1 才用
#                             # --force-with-lease --force-if-includes 覆寫殘留分支（絕不裸 -f）
# TI_AUTOPILOT_MERGE_ADMIN=0  # 預設不帶 gh pr merge --admin，讓分支保護生效；
#                             # 目標 branch 有保護規則且需自動合併時設 1
# TI_AUTOPILOT_PROTECTION_CHECK=1  # 第二道防線：squash-merge 前主動查「合併目標分支
#                             # （TI_AUTOPILOT_BRANCH，預設 main）」的保護狀態。優先打 Rulesets
#                             # 端點（gh api repos/<repo>/rules/branches/<branch>，classic token
#                             # 即可讀、多半不需 Administration:read），舊 branch protection 端點為輔。
#                             # 三態 fail-safe：受保護/無保護皆放行（受保護分支交由不帶 --admin 的
#                             # pr merge 自然攔下），唯「無法確認」（403 無權/網路/逾時）一律中止，
#                             # 回含「無法確認保護狀態」字樣的訊息，絕不誤判為無保護放行。
#                             # 註：讀「舊 protection 端點」需 token 具 Administration:read；無此權限
#                             # 而每次卡在「無法確認」的部署環境，設 0 可整段跳過此檢查（明確逃生口）。
